# SECURITATE: Blochează accesul direct la toate fișierele
# JSON, DB, TXT și alte date sensibile

# Deny all by default
Order deny,allow
Deny from all

# Block directory listing
Options -Indexes

# Extra protection for sensitive files
<FilesMatch "\.(json|db|sqlite|txt|log|bak)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Block hidden files
<FilesMatch "^\.">
    Order deny,allow
    Deny from all
</FilesMatch>
